# Default: normalize line endings to LF in the repo
* text=auto

# Shell scripts must always be LF (required for Linux CI runners)
*.sh        text eol=lf
gradlew     text eol=lf

# Windows batch files use CRLF
*.bat       text eol=crlf
*.ps1       text eol=crlf

# Binaries — no line-ending conversion
*.jar       binary
*.png       binary
*.jpg       binary
*.ico       binary
*.apk       binary
*.aab       binary
*.keystore  binary
