# Copy this file to keystore.properties (gitignored) and fill in your values.
# Used for release builds. Without this file, only debug APKs can be built locally.
#
# For CI, these values are injected from GitHub Actions secrets:
#   KEYSTORE_BASE64, KEYSTORE_PASSWORD, KEY_ALIAS, KEY_PASSWORD

storeFile=countdown-release.jks
storePassword=YOUR_STORE_PASSWORD
keyAlias=countdown
keyPassword=YOUR_KEY_PASSWORD
