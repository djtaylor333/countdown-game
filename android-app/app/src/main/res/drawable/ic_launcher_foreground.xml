<?xml version="1.0" encoding="utf-8"?>
<!-- Countdown clock icon — gold "C" arc with clock hands -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Gold "C" arc — open circle representing Countdown ring -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#F59E0B"
        android:strokeWidth="8"
        android:strokeLineCap="round"
        android:pathData="M 80,54 A 26,26 0 1,1 79.5,46" />

    <!-- Minute hand (pointing up-left) -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#F59E0B"
        android:strokeWidth="4"
        android:strokeLineCap="round"
        android:pathData="M54,54 L54,34" />

    <!-- Hour hand (pointing right) -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#F59E0B"
        android:strokeWidth="3"
        android:strokeLineCap="round"
        android:pathData="M54,54 L68,54" />

    <!-- Center dot -->
    <path
        android:fillColor="#F59E0B"
        android:pathData="M54,54 m-3,0 a3,3 0 1,0 6,0 a3,3 0 1,0 -6,0" />
</vector>
